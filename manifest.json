{
  "manifest_version": 3,
  "name": "WordPress Browser Extension",
  "version": "0.7.0",
  "short_name": "WordPress",
  "description": "Detect WordPress sites, jump to the editor, identify the host, toggle the admin bar, and more.",
  "author": "Jake Goldman, Partner at Fueled",
  "homepage_url": "https://github.com/jakemgold/wp-detective",

  "action": {
    "default_title": "WordPress Browser Extension",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "popup/popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/early.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["lib/detect.js", "lib/rest.js", "lib/host.js", "lib/block-inspector.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies"
  ],

  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],

  "commands": {
    "edit-this-page": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Alt+Shift+E"
      },
      "description": "Edit this page in WordPress"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
