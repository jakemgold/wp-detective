{
  "name": "wp-detective",
  "version": "0.7.0",
  "private": true,
  "description": "Chrome extension that detects WordPress sites and surfaces admin/developer shortcuts.",
  "scripts": {
    "build": "cross-env NODE_ENV=production TENUP_NO_EXTERNALS=true 10up-toolkit build",
    "start": "cross-env NODE_ENV=development TENUP_NO_EXTERNALS=true 10up-toolkit start"
  },
  "dependencies": {
    "@wordpress/icons": "^12.2.0",
    "@wordpress/ui": "^0.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "10up-toolkit": "^6.5.1",
    "cross-env": "^7.0.3"
  },
  "overrides": {
    "webpack": "5.99.0"
  }
}
