{
  "name": "wordpress-browser-extension",
  "version": "0.8.1",
  "private": true,
  "description": "Browser extension that detects WordPress sites and surfaces admin/developer shortcuts.",
  "scripts": {
    "build": "cross-env NODE_ENV=production TENUP_NO_EXTERNALS=true 10up-toolkit build",
    "start": "cross-env NODE_ENV=development TENUP_NO_EXTERNALS=true 10up-toolkit start",
    "build:safari": "npm run build && bash scripts/sync-safari.sh",
    "package:chrome": "bash scripts/package-chrome.sh"
  },
  "dependencies": {
    "@wordpress/icons": "^12.2.0",
    "@wordpress/ui": "^0.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "10up-toolkit": "^6.5.1",
    "cross-env": "^7.0.3",
    "sharp": "^0.34.5"
  },
  "overrides": {
    "webpack": "5.99.0"
  }
}
